

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/l2_db?schema=public"

JWT_SECRET="replace-with-a-long-random-string-at-least-32-characters"
NODE_ENV=staging
PORT=3000

NEXT_PUBLIC_API_URL=http://localhost:3000

# ZeptoMail — required for email OTP sign-in and notification emails
# Dashboard: Mail Agents → your agent → API Tokens → Add Token
# Canada accounts use api.zeptomail.ca (not .com)
ZEPTOMAIL_API_URL=https://api.zeptomail.ca
ZEPTOMAIL_API_KEY=Zoho-enczapikey your-token-here

MAIL_FROM_ADDRESS=noreply@locumlink.ca
MAIL_FROM_NAME=Locum Link

# IANA timezone for shift schedule comparisons (browse filter, expiry cron)
PLATFORM_TIMEZONE=America/Halifax

# Admin JWT (email/password auth — see docs/ADMIN_AUTH.md)
ADMIN_JWT_SECRET=
ADMIN_FRONTEND_REDIRECT_URL=http://localhost:3001/admin
