# Copy to `.env` or `.env.staging` (see backend ConfigModule envFilePath).
# Use the same DATABASE_URL and JWT_SECRET in `frontend/.env.local` (Next.js API routes).
# From repo root: `docker compose up -d` then `npm run db:prepare`.
# Local Postgres listens on port 5433 by default.

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/l2_db?schema=public"

# Required — must match the secret used to sign JWTs the frontend stores (ll_access).
# Generate: openssl rand -hex 32
# JWT_SECRET="replace-with-a-long-random-string-at-least-32-characters"
JWT_SECRET="a11fea048e80f92476526e846df62f8bd945512d472dfc97537a9541d5c76c18"
NODE_ENV=staging
PORT=3000

# Supabase (required for /api/auth/sync-supabase during OTP login)
# Frontend (Next) talks to Nest; default matches backend PORT above.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Supabase (Project Settings → API) — use the same project for NEXT_PUBLIC_* and SUPABASE_*.

NEXT_PUBLIC_SUPABASE_URL=https://ayvnfplwmvaprqfsbpmh.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_Az1HzJdsx39HA01oq0Q-PQ_lRTWYg_V
