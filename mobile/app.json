{
  "expo": {
    "name": "Locum Link",
    "slug": "locum-link",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "calocumlinkapp",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ca.locumlink.app",
      "buildNumber": "5",
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:locumlink.ca",
        "applinks:staging.locumlink.ca"
      ],
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ],
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserNotificationsUsageDescription": "Locum Link sends alerts for messages, applications, and account updates.",
        "NSCameraUsageDescription": "Locum Link uses the camera so you can take a profile photo or upload credential documents.",
        "NSPhotoLibraryUsageDescription": "Locum Link accesses your photo library so you can choose a profile photo or upload credential documents.",
        "NSPhotoLibraryAddUsageDescription": "Locum Link can save photos you choose to upload for your profile or credentials."
      }
    },
    "android": {
      "package": "ca.locumlink.app",
      "permissions": [
        "POST_NOTIFICATIONS",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-dev-client",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#38C6C6"
        }
      ],
      "expo-apple-authentication"
    ],
    "extra": {
      "eas": {
        "projectId": "cc191bc9-a1a5-4609-8326-cc2db4fb0ef6"
      }
    },
    "owner": "satyam_gautam24"
  }
}
